## ai_workflow local runtime env (example)
##
## Copy to: /Users/june-young/Research_Local/08_GWAS_browser/ver_260201_toy_gwas_browser/ai_workflow/.env.local
## Then start the app normally; it will auto-load this file on startup.
##
## Notes:
## - This file is for runtime convenience; contract_tests must still pass without it.
## - Values here only apply if the variable is NOT already set in your shell.

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL_CHAT=deepseek-r1:32b

# Enable remote GWAS trait search fallback (/api/search-traits remote enrichment)
GWAS_REMOTE_SEARCH=1

# Build a large local trait cache for good partial search (e.g., "Obes" -> obesity)
# Auto-detected by default if a gwas_catalog_trait-mappings_*.tsv exists one directory above the project root.
GWAS_TRAIT_LIST_AUTOBOOTSTRAP=1
GWAS_TRAIT_MAPPINGS_TSV_PATH=/Users/june-young/Research_Local/08_GWAS_browser/gwas_catalog_trait-mappings_r2025-09-04.tsv

# Treat GWAS cache as stale if PubMed is missing (forces refetch)
GWAS_CACHE_REQUIRE_PUBMED=1

# Optional: seed GWAS cache from another project version to avoid refetching everything.
# If omitted, the app will auto-detect the best sibling cache dir when the current cache is empty.
#GWAS_CACHE_SEED_DIR=/Users/june-young/Research_Local/08_GWAS_browser/ver_250904_claude_/data/gwas_cache

# ForeGenomics PGx report file (optional override)
# IMPORTANT:
# - Use the *report* TSV produced per sample, e.g.:
#   ForeGenomics_PGx/trial/<SAMPLE>/<SAMPLE>.PGx.out.report.tsv
# - Preferred (Phase 7): point to the trial directory; backend picks report by session sample_id.
FOREGENOMICS_PGX_ROOT=/Users/june-young/Research_Local/08_GWAS_browser/ForeGenomics_PGx/trial
#
# Optional fallback: force a single report file (then different VCFs may look identical)
#FOREGENOMICS_PGX_REPORT_PATH=/Users/june-young/Research_Local/08_GWAS_browser/ForeGenomics_PGx/trial/<SAMPLE>/<SAMPLE>.PGx.out.report.tsv
